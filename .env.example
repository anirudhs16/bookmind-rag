# ── Required ──────────────────────────────────────────────────────────────────
# Your Groq API key (get one free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Qdrant Cloud (free tier at https://cloud.qdrant.io)
# After signup: create a cluster → copy the URL and API key
QDRANT_URL=https://YOUR-CLUSTER-ID.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose logging
DEBUG=false
